{
  "manifest_version": 3,
  "name": "Extension Guard",
  "description": "Chrome extension auditor focused on permissions, host access and local risk scoring.",
  "version": "1.0.0",
  "minimum_chrome_version": "116",
  "permissions": ["management", "storage", "sidePanel"],
  "host_permissions": [],
  "background": {
    "service_worker": "background/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Extension Guard",
    "default_popup": "src/app/popup/index.html"
  },
  "side_panel": {
    "default_path": "src/app/sidepanel/index.html"
  },
  "options_page": "src/app/options/index.html",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
